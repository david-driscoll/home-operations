# Cluster configuration — values used by init.sh at runtime
# DNS_CLUSTER_DOMAIN=dns.driscoll.tech
# DNS_CLUSTER_IS_PRIMARY=${DNS_CLUSTER_IS_PRIMARY}
# DNS_CLUSTER_NODE_IP=${tailscaleIpAddress}
# DNS_CLUSTER_PRIMARY_IP=100.111.30.100
# DNS_CLUSTER_PRIMARY_URL=https://technitium.celestia.driscoll.tech


DNS_SERVER_DOMAIN="dns.${searchDomain}"
DNS_SERVER_ADMIN_PASSWORD="op://Eris/Technitium Password/password"
# DNS_SERVER_FORWARDERS="100.100.100.100"
# DNS_SERVER_PREFER_IPV6
# DNS_SERVER_WEB_SERVICE_LOCAL_ADDRESSES
# DNS_SERVER_WEB_SERVICE_HTTP_PORT
# DNS_SERVER_WEB_SERVICE_HTTPS_PORT
# DNS_SERVER_WEB_SERVICE_ENABLE_HTTPS
# DNS_SERVER_WEB_SERVICE_USE_SELF_SIGNED_CERT
DNS_SERVER_WEB_SERVICE_TLS_CERTIFICATE_PATH="/etc/technitium/certs/${CLUSTER_KEY}.dns.${searchDomain}/${CLUSTER_KEY}.dns.${searchDomain}.pfx"
DNS_SERVER_WEB_SERVICE_TLS_CERTIFICATE_PASSWORD=""
# DNS_SERVER_WEB_SERVICE_HTTP_TO_TLS_REDIRECT
# DNS_SERVER_OPTIONAL_PROTOCOL_DNS_OVER_HTTP
DNS_SERVER_RECURSION="AllowOnlyForPrivateNetworks"
# DNS_SERVER_RECURSION_NETWORK_ACL
# DNS_SERVER_RECURSION_DENIED_NETWORKS
# DNS_SERVER_RECURSION_ALLOWED_NETWORKS
DNS_SERVER_ENABLE_BLOCKING="true"
DNS_SERVER_ALLOW_TXT_BLOCKING_REPORT="false"
# DNS_SERVER_BLOCK_LIST_URLS
DNS_SERVER_FORWARDERS="9.9.9.9, 149.112.112.112"
DNS_SERVER_PREFER_IPV6=false
DNS_SERVER_FORWARDER_PROTOCOL="Tls"
DNS_SERVER_LOG_USING_LOCAL_TIME="true"
# DNS_SERVER_LOG_MAX_LOG_FILE_DAYS
DNS_SERVER_STATS_ENABLE_IN_MEMORY_STATS="true"
# DNS_SERVER_STATS_MAX_STAT_FILE_DAYS
DNS_SERVER_SSO_ENABLED=true
DNS_SERVER_SSO_AUTHORITY="op://Eris/${CLUSTER_KEY}-${APP}-oidc-credentials/issuer"
DNS_SERVER_SSO_CLIENT_ID="op://Eris/${CLUSTER_KEY}-${APP}-oidc-credentials/client_id"
DNS_SERVER_SSO_CLIENT_SECRET="op://Eris/${CLUSTER_KEY}-${APP}-oidc-credentials/client_secret"
DNS_SERVER_SSO_ALLOW_SIGNUP=true
DNS_SERVER_SSO_ALLOW_SIGNUP_ONLY_FOR_MAPPED_USERS=true
DNS_SERVER_SSO_GROUP_MAP=admins:Administrators
DNS_SERVER_SSO_SCOPES="openid,profile,email"
TS_AUTHKEY="${TS_DNS_AUTHKEY}"
TS_HOSTNAME="${CLUSTER_KEY}-dns"

ANIMATIONS_ENABLED="true"
APPLICATION_THEME="dark"
GLASS_EFFECTS_ENABLED="true"
ICON_CATALOG="arcane"
KEYBOARD_SHORTCUTS_ENABLED="true"
MOBILE_NAVIGATION_MODE="docked" # floating

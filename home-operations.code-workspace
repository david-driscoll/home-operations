{
	"folders": [
		{
			"name": "home-operations",
			"path": "."
		},
		{
			"name": "vault",
			"path": "../vault"
		},
		{
			"name": "stargate-command-cluster",
			"path": "../stargate-command-cluster"
		},
		{
			"name": "equestria-cluster",
			"path": "../equestria-cluster"
		}
	],
	"settings": {
		"editor.bracketPairColorization.enabled": true,
		"files.trimTrailingWhitespace": true,
		"files.exclude": {
			"**/.git": true,
			"**/.svn": true,
			"**/.hg": true,
			"**/.DS_Store": true,
			"**/Thumbs.db": true,
			"sdks/**": true,
			"node_modules/**": true,
			"**/.agents/**": true,
			"**/.claude/**": true,
			"**/.venv/**": true,
			"**/.github/agents/**": true,
			"**/.github/hooks/**": true,
			"**/.github/instructions/**": true,
			"**/.github/mcp.json": true,
			"**/.github/copilot-instructions.md": true,
			"**/.github/prompts/**": true,
			"**/bin/**": true,
			"**/apm_modules/**": true
		},
		"sops.defaults.ageKeyFile": "../stargate-command-cluster/age.key",
		"sops.binPath": "/opt/homebrew/bin/sops",
		"sops.beta": false,
		"sops.creationEnabled": true,
		"path-autocomplete.disableUpOneFolder": false,
		"path-autocomplete.triggerOutsideStrings": true,
		"cSpell.words": [
			"Authentik",
			"AUTHKEY",
			"celestia",
			"certresolver",
			"dockge",
			"gatus",
			"pulumi",
			"sysctls",
			"technitium",
			"USERSPACE",
			"websecure"
		],
		"vs-kubernetes": {
			"vs-kubernetes.crd-code-completion": "enabled",
			"vs-kubernetes.namespace": "",
			// "vs-kubernetes.kubectl-path": "",
			// "vs-kubernetes.helm-path": "",
			// "vs-kubernetes.minikube-path": "",
			// "vs-kubernetes.kubectlVersioning": "user-provided",
			"vs-kubernetes.outputFormat": "yaml",
			"vs-kubernetes.kubeconfig": "",
			"vs-kubernetes.knownKubeconfigs": [
				"/Users/david/Development/david-driscoll/equestria-cluster/kubeconfig"
			],
			"vs-kubernetes.autoCleanupOnDebugTerminate": false,
			"vs-kubernetes.nodejs-autodetect-remote-root": true,
			"vs-kubernetes.nodejs-remote-root": "",
			"vs-kubernetes.nodejs-debug-port": 9229,
			"vs-kubernetes.dotnet-vsdbg-path": "~/vsdbg/vsdbg",
			"vs-kubernetes.local-tunnel-debug-provider": "",
			"checkForMinikubeUpgrade": true,
			"imageBuildTool": "Docker"
		},
		"workbench.colorCustomizations": {
			"activityBar.activeBackground": "#c1698b",
			"activityBar.background": "#c1698b",
			"activityBar.foreground": "#15202b",
			"activityBar.inactiveForeground": "#15202b99",
			"activityBarBadge.background": "#3a5a25",
			"activityBarBadge.foreground": "#e7e7e7",
			"editorGroup.border": "#c1698b",
			"panel.border": "#c1698b",
			"sash.hoverBorder": "#c1698b",
			"sideBar.border": "#c1698b",
			"statusBar.background": "#c1698b",
			"statusBar.debuggingBackground": "#69c19f",
			"statusBar.debuggingForeground": "#15202b",
			"statusBar.foreground": "#15202b",
			"statusBarItem.hoverBackground": "#af4870",
			"statusBarItem.remoteBackground": "#c1698b",

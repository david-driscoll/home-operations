{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "account.ts",
        "bgp.ts",
        "client.ts",
        "clientQosRate.ts",
        "config/index.ts",
        "config/vars.ts",
        "device.ts",
        "dnsRecord.ts",
        "dynamicDns.ts",
        "firewallGroup.ts",
        "firewallPolicy.ts",
        "firewallRule.ts",
        "firewallZone.ts",
        "getAccount.ts",
        "getApGroup.ts",
        "getClient.ts",
        "getClientInfo.ts",
        "getClientInfoList.ts",
        "getClientList.ts",
        "getClientQosRate.ts",
        "getDnsRecord.ts",
        "getFirewallZone.ts",
        "getNetwork.ts",
        "getPortProfile.ts",
        "getRadiusProfile.ts",
        "getRadiusUser.ts",
        "index.ts",
        "network.ts",
        "portForward.ts",
        "portProfile.ts",
        "powerSupervisor.ts",
        "provider.ts",
        "radiusProfile.ts",
        "radiusUser.ts",
        "setting.ts",
        "site.ts",
        "siteToSiteVpn.ts",
        "staticRoute.ts",
        "trafficRoute.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "vpnClient.ts",
        "vpnServer.ts",
        "wan.ts",
        "wireguardPeer.ts",
        "wlan.ts"
    ]
}

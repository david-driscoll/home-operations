{
  "inputs": [],
  "servers": {
    "cloudflare-api": {
      "headers": {},
      "type": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "cloudflare-bindings": {
      "headers": {},
      "type": "http",
      "url": "https://bindings.mcp.cloudflare.com/mcp"
    },
    "cloudflare-builds": {
      "headers": {},
      "type": "http",
      "url": "https://builds.mcp.cloudflare.com/mcp"
    },
    "cloudflare-docs": {
      "headers": {},
      "type": "http",
      "url": "https://docs.mcp.cloudflare.com/mcp"
    },
    "cloudflare-observability": {
      "headers": {},
      "type": "http",
      "url": "https://observability.mcp.cloudflare.com/mcp"
    },
    "kubernetes": {
      "args": [
        "-y",
        "kubernetes-mcp-server"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "lean-ctx": {
      "args": [],
      "command": "lean-ctx",
      "type": "stdio"
    },
    "mise": {
      "args": [
        "mcp"
      ],
      "command": "mise",
      "env": {
        "MISE_EXPERIMENTAL": "1"
      },
      "type": "stdio"
    },
    "pulumi": {
      "args": [
        "-y",
        "@pulumi/mcp-server",
        "stdio"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "unifi-access": {
      "args": [
        "run",
        "--no-masking",
        "--",
        "uvx",
        "--python-preference",
        "system",
        "unifi-access-mcp==0.3.1"
      ],
      "command": "op",
      "env": {
        "UNIFI_ACCESS_API_KEY": "${UNIFI_API_KEY:-}",
        "UNIFI_ACCESS_API_PORT": "${UNIFI_API_PORT:-12445}",
        "UNIFI_ACCESS_HOST": "${UNIFI_HOST:-}",
        "UNIFI_ACCESS_PASSWORD": "${UNIFI_PASSWORD:-}",
        "UNIFI_ACCESS_PORT": "${UNIFI_PORT:-443}",
        "UNIFI_ACCESS_USERNAME": "${UNIFI_USERNAME:-}",
        "UNIFI_ACCESS_VERIFY_SSL": "${UNIFI_VERIFY_SSL:-false}",
        "UNIFI_HOST": "${UNIFI_HOST:-}",
        "UNIFI_PASSWORD": "${UNIFI_PASSWORD:-}",
        "UNIFI_PORT": "${UNIFI_PORT:-443}",
        "UNIFI_TOOL_REGISTRATION_MODE": "${UNIFI_TOOL_REGISTRATION_MODE:-lazy}",
        "UNIFI_USERNAME": "${UNIFI_USERNAME:-}",
        "UNIFI_VERIFY_SSL": "${UNIFI_VERIFY_SSL:-false}"
      },
      "type": "stdio"
    },
    "unifi-network": {
      "args": [
        "run",
        "--no-masking",
        "--",
        "uvx",
        "--python-preference",
        "system",
        "unifi-network-mcp==0.18.2"
      ],
      "command": "op",
      "env": {
        "UNIFI_HOST": "${UNIFI_HOST:-}",
        "UNIFI_NETWORK_HOST": "${UNIFI_HOST:-}",
        "UNIFI_NETWORK_PASSWORD": "${UNIFI_PASSWORD:-}",
        "UNIFI_NETWORK_PORT": "${UNIFI_PORT:-443}",
        "UNIFI_NETWORK_SITE": "${UNIFI_SITE:-default}",
        "UNIFI_NETWORK_USERNAME": "${UNIFI_USERNAME:-}",
        "UNIFI_NETWORK_VERIFY_SSL": "${UNIFI_VERIFY_SSL:-false}",
        "UNIFI_PASSWORD": "${UNIFI_PASSWORD:-}",
        "UNIFI_PORT": "${UNIFI_PORT:-443}",
        "UNIFI_SITE": "${UNIFI_SITE:-default}",
        "UNIFI_TOOL_REGISTRATION_MODE": "${UNIFI_TOOL_REGISTRATION_MODE:-lazy}",
        "UNIFI_USERNAME": "${UNIFI_USERNAME:-}",
        "UNIFI_VERIFY_SSL": "${UNIFI_VERIFY_SSL:-false}"
      },
      "type": "stdio"
    },
    "unifi-protect": {
      "args": [
        "run",
        "--no-masking",
        "--",
        "uvx",
        "--python-preference",
        "system",
        "unifi-protect-mcp==0.4.2"
      ],
      "command": "op",
      "env": {
        "UNIFI_HOST": "${UNIFI_HOST:-}",
        "UNIFI_PASSWORD": "${UNIFI_PASSWORD:-}",
        "UNIFI_PORT": "${UNIFI_PORT:-443}",
        "UNIFI_PROTECT_HOST": "${UNIFI_HOST:-}",
        "UNIFI_PROTECT_PASSWORD": "${UNIFI_PASSWORD:-}",
        "UNIFI_PROTECT_PORT": "${UNIFI_PORT:-443}",
        "UNIFI_PROTECT_USERNAME": "${UNIFI_USERNAME:-}",
        "UNIFI_PROTECT_VERIFY_SSL": "${UNIFI_VERIFY_SSL:-false}",
        "UNIFI_TOOL_REGISTRATION_MODE": "${UNIFI_TOOL_REGISTRATION_MODE:-lazy}",
        "UNIFI_USERNAME": "${UNIFI_USERNAME:-}",
        "UNIFI_VERIFY_SSL": "${UNIFI_VERIFY_SSL:-false}"
      },
      "type": "stdio"
    }
  }
}

{
  "inputs": [],
  "servers": {
    "kubernetes": {
      "args": [
        "-y",
        "kubernetes-mcp-server"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "lean-ctx": {
      "args": [],
      "command": "lean-ctx",
      "type": "stdio"
    },
    "mise": {
      "args": [
        "mcp"
      ],
      "command": "mise",
      "env": {
        "MISE_EXPERIMENTAL": "1"
      },
      "type": "stdio"
    },
    "pulumi": {
      "args": [
        "-y",
        "@pulumi/mcp-server",
        "stdio"
      ],
      "command": "npx",
      "type": "stdio"
    }
  }
}
